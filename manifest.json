{
  "manifest_version": 3,
  "name": "dencoder",
  "version": "0.1.0",
  "description": "Developer toolbox for hashes, ciphers, encoding, JWT, JSON, networking, and conversions.",
  "homepage_url": "https://github.com/sm1ee/dencoder",
  "permissions": [
    "clipboardWrite"
  ],
  "action": {
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    },
    "default_title": "dencoder",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
